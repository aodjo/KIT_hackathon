{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "build": "npm run typecheck",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply echo-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply echo-db --remote",
    "db:exec:local": "wrangler d1 execute echo-db --local --file",
    "db:exec:remote": "wrangler d1 execute echo-db --remote --file",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.80.0"
  }
}
